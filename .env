# Database Configuration
DB_URL=jdbc:mysql://mysql:3306/marketplace_services?useUnicode=true&connectionCollation=utf8mb4_unicode_ci&serverTimezone=UTC
DB_USER=root
DB_PASSWORD=dev
DB_NAME=marketplace_services
MYSQL_ROOT_PASSWORD=dev

# JWT (RF-001/RF-002) — secreto de firma y expiracion del token en milisegundos
JWT_SECRET=dev-serviya-jwt-secret-change-me-in-production
JWT_EXPIRATION_MS=3600000

# PII (RNF-005) — passphrase para el cifrado AES-256-GCM de document_number/phone_number
ENCRYPTION_KEY=dev-serviya-pii-encryption-key-change-me

# Frontend API URL (Vite build-time env var)
VITE_API_URL=http://localhost:8080

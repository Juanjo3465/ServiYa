# Database Configuration
DB_URL=jdbc:mysql://mysql:3306/marketplace_services?useUnicode=true&connectionCollation=utf8mb4_unicode_ci&serverTimezone=UTC
DB_USER=root
DB_PASSWORD=dev
DB_NAME=marketplace_services
MYSQL_ROOT_PASSWORD=dev

# JWT (RF-001/RF-002) — secreto de firma y expiracion del token en milisegundos
JWT_SECRET=dev-serviya-jwt-secret-change-me-in-production
JWT_EXPIRATION_MS=3600000

# PII (RNF-005) — passphrase para el cifrado AES-256-GCM de document_number/phone_number
ENCRYPTION_KEY=dev-serviya-pii-encryption-key-change-me

# Brevo API
EMAIL_ENABLED=true
EMAIL_API_KEY=key-brevo
EMAIL_FROM=example@serviya.com
EMAIL_FROM_NAME=ServiYa

# Recuperacion de contrasena (RF-003) — URL COMPLETA del enlace que viaja en el correo (el backend
# le agrega ?token=...). Debe incluir el path /reset-password. La compose de dev ya la sobreescribe
# a :5173. Vite dev: http://localhost:5173/reset-password | frontend dockerizado (prod): :8081
FRONTEND_RESET_URL=http://localhost:5173/reset-password

# Frontend API URL (Vite build-time env var)
# Vacío = URLs relativas → nginx proxya /api/ al backend. Funciona con ngrok.
# En dev, docker-compose.dev.yml lo sobreescribe a http://localhost:8080.
VITE_API_URL=
